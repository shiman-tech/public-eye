{
  "name": "civicpulse",
  "private": true,
  "version": "1.0.0",
  "description": "CivicPulse — FARM stack monorepo (FastAPI + React + Supabase)",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "docker compose up --build backend",
    "dev:backend:down": "docker compose down",
    "docker:build": "docker compose build backend",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
